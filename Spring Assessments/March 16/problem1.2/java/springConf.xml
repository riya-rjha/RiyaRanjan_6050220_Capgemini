<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="emp1" class="cg.demo.spring.beans.Employee">
    	<property name="employeeId" value="12345"></property>
    	<property name="employeeName" value="Satish"></property>
    	<property name="salary" value="40000.0"></property>
    	<property name="businessUnit" value="PES-BU"></property>
    	<property name="age" value="30"></property>
    	<property name="sbu" ref="sbu1"></property>
    </bean>
    
    <bean id="sbu1" class="cg.demo.spring.beans.SBU">
    	<constructor-arg value="101"></constructor-arg>
    	<constructor-arg value="AI Engineer"></constructor-arg>
    	<constructor-arg value="Sunil Gavaskar"></constructor-arg>
    </bean>

</beans>